{
  "openapi": "3.1.0",
  "info": { "title": "Create Prediction", "version": "1.0.0" },
  "servers": [{ "url": "https://api.shuyou.ai" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/v1/predictions": {
      "post": {
        "tags": ["Task Management"],
        "summary": "Create Prediction",
        "description": "- Submit an asynchronous prediction job (image, video, or other hosted models)\n- Poll status with [Get Prediction](/en/api-manual/task-management/get-prediction)\n- Common for Replicate-style model slugs such as `replicate/black-forest-labs/flux-schnell`",
        "operationId": "createPrediction",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/PredictionRequest" },
              "examples": {
                "flux": {
                  "summary": "Flux Schnell",
                  "value": {
                    "model": "replicate/black-forest-labs/flux-schnell",
                    "input": { "prompt": "A futuristic city at night" }
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Prediction created",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PredictionResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "PredictionRequest": {
        "type": "object",
        "required": ["model", "input"],
        "properties": {
          "model": {
            "type": "string",
            "description": "Hosted model identifier",
            "example": "replicate/black-forest-labs/flux-schnell"
          },
          "input": {
            "type": "object",
            "additionalProperties": true,
            "description": "Model-specific input payload"
          }
        }
      },
      "PredictionResponse": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "example": "pred_abc123" },
          "status": {
            "type": "string",
            "enum": ["starting", "processing", "succeeded", "failed", "canceled"]
          },
          "output": { "type": "object", "additionalProperties": true }
        },
        "additionalProperties": true
      }
    }
  }
}
