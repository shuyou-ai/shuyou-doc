{
  "openapi": "3.1.0",
  "info": { "title": "List Files", "version": "1.0.0" },
  "servers": [{ "url": "https://api.shuyou.ai" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/v1/files": {
      "get": {
        "tags": ["File Series"],
        "summary": "List Files",
        "description": "- List files uploaded to your account\n- Filter by `purpose` when needed\n- Pair with [Upload File](/zh/api-manual/file-series/upload-stream) and [Delete File](/zh/api-manual/file-series/delete-file)",
        "operationId": "listFiles",
        "parameters": [
          {
            "name": "purpose",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string",
              "enum": ["assistants", "batch", "fine-tune", "vision", "user_data"]
            },
            "description": "Filter files by purpose"
          }
        ],
        "responses": {
          "200": {
            "description": "File list",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/FileList" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "FileList": {
        "type": "object",
        "properties": {
          "object": { "type": "string", "example": "list" },
          "data": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/FileObject" }
          }
        }
      },
      "FileObject": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "object": { "type": "string" },
          "bytes": { "type": "integer" },
          "created_at": { "type": "integer" },
          "filename": { "type": "string" },
          "purpose": { "type": "string" },
          "status": { "type": "string" }
        }
      }
    }
  }
}
