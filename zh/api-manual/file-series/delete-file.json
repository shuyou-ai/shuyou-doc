{
  "openapi": "3.1.0",
  "info": { "title": "Delete File", "version": "1.0.0" },
  "servers": [{ "url": "https://api.shuyou.ai" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/v1/files/{file_id}": {
      "delete": {
        "tags": ["File Series"],
        "summary": "Delete File",
        "description": "- Permanently delete an uploaded file by ID\n- Obtain file IDs from [Upload File](/zh/api-manual/file-series/upload-stream) or [List Files](/zh/api-manual/file-series/list-files)",
        "operationId": "deleteFile",
        "parameters": [
          {
            "name": "file_id",
            "in": "path",
            "required": true,
            "schema": { "type": "string" },
            "example": "file_abc123",
            "description": "File ID returned from upload"
          }
        ],
        "responses": {
          "200": {
            "description": "File deleted",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "object": { "type": "string", "example": "file" },
                    "deleted": { "type": "boolean", "example": true }
                  }
                }
              }
            }
          },
          "404": { "description": "File not found" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    }
  }
}
