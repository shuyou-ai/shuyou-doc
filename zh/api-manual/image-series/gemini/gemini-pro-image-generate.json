{
  "openapi": "3.1.0",
  "info": {
    "title": "Gemini Pro Image Generation",
    "version": "1.0.0"
  },
  "servers": [{ "url": "https://api.shuyou.ai" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/v1/images/generations": {
      "post": {
        "tags": ["Image Generation"],
        "summary": "Gemini Pro Image Generation",
        "description": "- Model: `google/gemini-3-pro-image-preview` — higher quality image generation\n- Supports text-to-image and image-to-image via `image_urls`\n- Poll usage via [Get Generation](/en/api-manual/task-management/get-generation)",
        "operationId": "createGeminiProImageGeneration",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ImageGenerationRequest" },
              "examples": {
                "text_to_image": {
                  "summary": "Text to Image",
                  "value": {
                    "model": "google/gemini-3-pro-image-preview",
                    "prompt": "A nano banana dish in a fancy restaurant with a Gemini theme",
                    "size": "1024x1024",
                    "n": 1
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ImageGenerationResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "`Authorization: Bearer YOUR_API_KEY`"
      }
    },
    "schemas": {
      "ImageGenerationRequest": {
        "type": "object",
        "required": ["model", "prompt"],
        "properties": {
          "model": {
            "type": "string",
            "enum": ["google/gemini-3-pro-image-preview"],
            "default": "google/gemini-3-pro-image-preview"
          },
          "prompt": { "type": "string", "maxLength": 2000 },
          "size": { "type": "string", "example": "1024x1024" },
          "n": { "type": "integer", "minimum": 1, "maximum": 4, "default": 1 },
          "image_urls": {
            "type": "array",
            "items": { "type": "string", "format": "uri" }
          }
        }
      },
      "ImageGenerationResponse": {
        "type": "object",
        "properties": {
          "created": { "type": "integer" },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": { "type": "string", "format": "uri" },
                "b64_json": { "type": "string" }
              }
            }
          }
        }
      }
    }
  }
}
