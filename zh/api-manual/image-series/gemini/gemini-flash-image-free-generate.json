{
  "openapi": "3.1.0",
  "info": { "title": "Gemini Flash Image Generation (Free)", "version": "1.0.0" },
  "servers": [{ "url": "https://api.shuyou.ai" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/v1/images/generations": {
      "post": {
        "tags": ["Image Generation"],
        "summary": "Gemini Flash Image Generation (Free)",
        "description": "- Model: `google/gemini-2.5-flash-image-free`\n- Same OpenAI Images API as the paid Flash model\n- Subject to free-tier rate limits and availability",
        "operationId": "createGeminiFlashImageFreeGeneration",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ImageGenerationRequest" },
              "examples": {
                "text_to_image": {
                  "value": {
                    "model": "google/gemini-2.5-flash-image-free",
                    "prompt": "A simple sketch of a mountain at sunset"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ImageGenerationResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "ImageGenerationRequest": {
        "type": "object",
        "required": ["model", "prompt"],
        "properties": {
          "model": {
            "type": "string",
            "enum": ["google/gemini-2.5-flash-image-free"],
            "default": "google/gemini-2.5-flash-image-free"
          },
          "prompt": { "type": "string" },
          "size": { "type": "string" },
          "n": { "type": "integer", "default": 1 }
        }
      },
      "ImageGenerationResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": { "url": { "type": "string" } }
            }
          }
        }
      }
    }
  }
}
