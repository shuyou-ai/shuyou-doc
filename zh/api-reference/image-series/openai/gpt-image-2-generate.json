{
  "openapi": "3.1.0",
  "info": {
    "title": "GPT Image 2 图像生成",
    "version": "1.0.0"
  },
  "servers": [{ "url": "https://api.shuyou.ai" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/v1/predictions": {
      "post": {
        "tags": ["图像生成"],
        "summary": "GPT Image 2 图像生成",
        "operationId": "createGptImage2Prediction",
        "description": "GPT Image 2（`gpt-image-2`）支持文生图、图生图、图像编辑。`input` 优先使用官方字段（`size`、`n`、`quality` 等）；未传时可使用 ShuYou 平台字段（`aspect_ratio`、`num_images`、`output_format`）。异步：用 `data.task_id` 查询预测任务，或配置顶层 `webhook`。图像链接 24 小时有效。",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GptImage2PredictionRequest" },
              "examples": {
                "text_to_image": {
                  "summary": "文生图（最简）",
                  "value": {
                    "model": "gpt-image-2",
                    "function": "image",
                    "input": {
                      "prompt": "海面上绚丽多彩的美丽日落"
                    }
                  }
                },
                "text_to_image_hd": {
                  "summary": "文生图（高清 16:9）",
                  "value": {
                    "model": "gpt-image-2",
                    "function": "image",
                    "input": {
                      "prompt": "黄昏时分未来都市天际线的电影级广角镜头",
                      "size": "16:9",
                      "resolution": "4K",
                      "quality": "high",
                      "n": 1
                    }
                  }
                },
                "text_to_image_pixel": {
                  "summary": "文生图（指定像素）",
                  "value": {
                    "model": "gpt-image-2",
                    "function": "image",
                    "input": {
                      "prompt": "极简主义 Logo 设计",
                      "size": "1024x1024",
                      "quality": "medium"
                    }
                  }
                },
                "image_edit": {
                  "summary": "图生图 / 图像编辑",
                  "value": {
                    "model": "gpt-image-2",
                    "function": "image",
                    "input": {
                      "prompt": "在她旁边加一只可爱的小猫",
                      "size": "1:1",
                      "resolution": "1K",
                      "quality": "medium",
                      "image_urls": ["https://example.com/input.png"]
                    },
                    "webhook": "https://your-domain.com/webhook/image-done"
                  }
                },
                "image_inpaint": {
                  "summary": "局部重绘（带 mask）",
                  "value": {
                    "model": "gpt-image-2",
                    "function": "image",
                    "input": {
                      "prompt": "把天空换成繁星点点的夜空",
                      "size": "1:1",
                      "resolution": "1K",
                      "quality": "medium",
                      "image_urls": ["https://example.com/input.png"],
                      "mask_url": "https://example.com/mask.png"
                    }
                  }
                },
                "batch_generation": {
                  "summary": "批量生成",
                  "value": {
                    "model": "gpt-image-2",
                    "function": "image",
                    "input": {
                      "prompt": "像素风格的可爱机器人",
                      "size": "1:1",
                      "resolution": "2K",
                      "quality": "high",
                      "n": 4
                    }
                  }
                },
                "platform_params": {
                  "summary": "ShuYou 平台字段",
                  "value": {
                    "model": "gpt-image-2",
                    "function": "image",
                    "input": {
                      "prompt": "生成一个 ShuYou AI logo，简约风格",
                      "aspect_ratio": "1:1",
                      "resolution": "1K",
                      "num_images": 1,
                      "output_format": "png",
                      "image_urls": []
                    },
                    "webhook": "https://api.shuyou.ai/api/callback"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "异步任务已创建",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/PredictionTaskResponse" },
                "example": {
                  "data": {
                    "task_id": "2c4d50261173430290971a2395a3b607",
                    "task_status": "processing"
                  }
                }
              }
            }
          },
          "400": {
            "description": "请求参数错误",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "401": {
            "description": "未认证、Token 无效或过期",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "402": {
            "description": "配额不足、需要充值",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "403": {
            "description": "无权限访问该模型",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "429": {
            "description": "请求频率超限",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "服务器内部错误",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "`Authorization: Bearer YOUR_API_KEY`"
      }
    },
    "schemas": {
      "GptImage2PredictionRequest": {
        "type": "object",
        "required": ["model", "function", "input"],
        "properties": {
          "model": {
            "type": "string",
            "description": "模型 ID。本接口请使用 `gpt-image-2`。",
            "enum": ["gpt-image-2"],
            "default": "gpt-image-2",
            "example": "gpt-image-2"
          },
          "function": {
            "type": "string",
            "description": "任务类型。图像生成必须为 `image`。",
            "enum": ["image"],
            "example": "image"
          },
          "input": { "$ref": "#/components/schemas/GptImage2Input" },
          "webhook": {
            "type": "string",
            "format": "uri",
            "description": "可选。任务完成、失败或取消时的 HTTPS 回调地址（Predictions API 顶层字段）。"
          }
        }
      },
      "GptImage2Input": {
        "type": "object",
        "required": ["prompt"],
        "properties": {
          "prompt": {
            "type": "string",
            "description": "提示词，描述要生成的图像，或描述如何编辑已输入的图像。最多 32000 个 Unicode 码点。",
            "maxLength": 32000,
            "example": "海面上绚丽多彩的美丽日落"
          },
          "image_urls": {
            "type": "array",
            "description": "参考图像 URL 列表，用于图生图与图像编辑。单次请求 1~16 张；单张不超过 50MB；支持 `.jpeg`、`.jpg`、`.png`、`.webp`。URL 需可被服务器直接访问。图生图/编辑会产生额外图像输入 token 消耗。",
            "items": { "type": "string", "format": "uri" },
            "minItems": 0,
            "maxItems": 16,
            "example": ["https://example.com/image1.png"]
          },
          "mask_url": {
            "type": "string",
            "format": "uri",
            "description": "局部重绘遮罩图 URL（仅图像编辑模式，须同时传 `image_urls`）。带 alpha 的 PNG：透明区域为重绘区，尺寸须与参考图完全一致。纯文生图时会被忽略。"
          },
          "size": {
            "type": "string",
            "description": "**官方字段（优先）。** 生成尺寸：比例、显式像素 `宽x高` 或 `auto`。若同时传 `size` 与 `aspect_ratio`，以 `size` 为准。默认 `auto`。",
            "default": "auto",
            "example": "auto"
          },
          "resolution": {
            "type": "string",
            "description": "分辨率档位，仅在 `size` 为比例格式时生效：`1K`（约 1 MP）、`2K`（约 4 MP）、`4K`（约 8.29 MP）。显式像素或 `auto` 时忽略。大小写不敏感。",
            "enum": ["1K", "2K", "4K"],
            "default": "1K",
            "example": "1K"
          },
          "quality": {
            "type": "string",
            "description": "渲染质量：`low`、`medium`、`high`，影响输出 token 与费用。默认 `medium`。",
            "enum": ["low", "medium", "high"],
            "default": "medium",
            "example": "medium"
          },
          "n": {
            "type": "integer",
            "description": "**官方字段（优先）。** 生成图片数量（1~10）。若同时传 `n` 与 `num_images`，以 `n` 为准。",
            "minimum": 1,
            "maximum": 10,
            "default": 1,
            "example": 1
          },
          "aspect_ratio": {
            "type": "string",
            "description": "**ShuYou 平台字段。** 画幅比例简写（如 `1:1`、`16:9`、`9:16`）。未传 `size` 时生效，与官方比例 `size` 等价；已传 `size` 时忽略。",
            "example": "1:1"
          },
          "num_images": {
            "type": "integer",
            "description": "**ShuYou 平台字段。** 生成图片张数。未传 `n` 时生效；已传 `n` 时忽略。",
            "minimum": 1,
            "maximum": 10,
            "default": 1,
            "example": 1
          },
          "output_format": {
            "type": "string",
            "description": "**ShuYou 平台字段。** 输出格式，如 `png`、`jpeg`、`webp`。可选，未传时使用模型或平台默认。",
            "example": "png"
          }
        }
      },
      "PredictionTaskResponse": {
        "type": "object",
        "properties": {
          "data": {
            "type": "object",
            "properties": {
              "task_id": {
                "type": "string",
                "description": "异步任务 ID，用于查询预测任务或关联回调。",
                "example": "2c4d50261173430290971a2395a3b607"
              },
              "task_status": {
                "type": "string",
                "description": "任务当前状态，如 `processing`。",
                "example": "processing"
              }
            },
            "required": ["task_id", "task_status"]
          }
        },
        "required": ["data"]
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
