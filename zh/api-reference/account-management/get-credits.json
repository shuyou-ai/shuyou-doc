{
  "openapi": "3.1.0",
  "info": {
    "title": "查询账户余额",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.shuyou.ai"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "paths": {
    "/v1/credits": {
      "get": {
        "tags": [
          "账户管理"
        ],
        "summary": "查询账户余额",
        "operationId": "getCredits",
        "description": "查询当前账户的总 credits、已用量与剩余余额。",
        "responses": {
          "200": {
            "description": "账户余额响应",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/GetCreditsResponse"
                },
                "example": {
                  "data": {
                    "total_credits": 100,
                    "total_usage": 25,
                    "balance": 75
                  }
                }
              }
            }
          },
          "401": {
            "description": "未认证"
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "`Authorization: Bearer YOUR_API_KEY`"
      }
    },
    "schemas": {
      "GetCreditsResponse": {
        "type": "object",
        "properties": {
          "data": {
            "$ref": "#/components/schemas/CreditsData"
          }
        },
        "required": [
          "data"
        ]
      },
      "CreditsData": {
        "type": "object",
        "properties": {
          "total_credits": {
            "type": "number",
            "format": "double",
            "description": "账户总 credits 额度。",
            "example": 100
          },
          "total_usage": {
            "type": "number",
            "format": "double",
            "description": "已消耗的 credits 总量。",
            "example": 25
          },
          "balance": {
            "type": "number",
            "format": "double",
            "description": "剩余 credits 余额（`total_credits` − `total_usage`）。",
            "example": 75
          }
        },
        "required": [
          "total_credits",
          "total_usage",
          "balance"
        ]
      }
    }
  }
}
