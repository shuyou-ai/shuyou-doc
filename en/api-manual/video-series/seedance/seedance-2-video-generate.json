{
  "openapi": "3.1.0",
  "info": { "title": "Seedance 2 Video Generation", "version": "1.0.0" },
  "servers": [{ "url": "https://api.shuyou.ai" }],
  "security": [{ "bearerAuth": [] }],
  "paths": {
    "/v1/publishers/{provider}/models/{model}:generateContent": {
      "post": {
        "tags": ["Video Generation"],
        "summary": "Seedance 2 Video Generation",
        "description": "- ByteDance Seedance 2 (`volcengine/doubao-seedance-2`) via Vertex-compatible API\n- Asynchronous video generation workflow",
        "operationId": "seedance2GenerateContent",
        "parameters": [
          {
            "name": "provider",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "volcengine" }
          },
          {
            "name": "model",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "example": "doubao-seedance-2" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/GenerateContentRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Success",
            "content": {
              "application/json": {
                "schema": { "type": "object", "additionalProperties": true }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer" }
    },
    "schemas": {
      "GenerateContentRequest": {
        "type": "object",
        "required": ["contents"],
        "properties": {
          "contents": {
            "type": "array",
            "items": { "type": "object", "additionalProperties": true }
          }
        }
      }
    }
  }
}
