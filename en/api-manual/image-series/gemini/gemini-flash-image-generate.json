{
  "openapi": "3.1.0",
  "info": {
    "title": "Gemini Flash Image Generation",
    "description": "Create image generation tasks using ShuYou-compatible OpenAI Images API.",
    "license": {
      "name": "MIT"
    },
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://api.shuyou.ai",
      "description": "Production"
    }
  ],
  "security": [
    {
      "bearerAuth": []
    }
  ],
  "tags": [
    {
      "name": "Image Generation",
      "description": "AI image generation APIs"
    }
  ],
  "paths": {
    "/v1/images/generations": {
      "post": {
        "tags": ["Image Generation"],
        "summary": "Gemini Flash Image Generation",
        "description": "- Supports text-to-image and image-to-image via `image_urls`\n- Compatible with OpenAI Images API format\n- For Vertex-native flows, see [Image Generation guide](/en/guide/advanced/image-generation)\n- Query usage via [Get Generation](/en/api-manual/task-management/get-generation)",
        "operationId": "createGeminiFlashImageGeneration",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ImageGenerationRequest"
              },
              "examples": {
                "text_to_image": {
                  "summary": "Text to Image",
                  "value": {
                    "model": "google/gemini-2.5-flash-image",
                    "prompt": "A cat playing on the grass",
                    "size": "1024x1024",
                    "n": 1
                  }
                },
                "image_to_image": {
                  "summary": "Image to Image",
                  "value": {
                    "model": "google/gemini-2.5-flash-image",
                    "prompt": "Turn the scene into watercolor style",
                    "image_urls": ["https://example.com/reference.png"]
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Image generation response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ImageGenerationResponse"
                }
              }
            }
          },
          "400": {
            "description": "Invalid request parameters",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "401": {
            "description": "Invalid or expired API key",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "429": {
            "description": "Rate limit exceeded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          },
          "500": {
            "description": "Internal server error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ErrorResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "description": "Add `Authorization: Bearer YOUR_API_KEY` to the request header. Create keys in the [ShuYou console](https://shuyou.ai/signin)."
      }
    },
    "schemas": {
      "ImageGenerationRequest": {
        "type": "object",
        "required": ["model", "prompt"],
        "properties": {
          "model": {
            "type": "string",
            "description": "Image model ID, e.g. `google/gemini-2.5-flash-image` or `google/gemini-3-pro-image-preview`.",
            "example": "google/gemini-2.5-flash-image"
          },
          "prompt": {
            "type": "string",
            "description": "Text prompt describing the image to generate or how to edit reference images.",
            "example": "A cat playing on the grass",
            "maxLength": 2000
          },
          "size": {
            "type": "string",
            "description": "Output size. Supported values depend on the model.",
            "example": "1024x1024"
          },
          "n": {
            "type": "integer",
            "description": "Number of images to generate.",
            "minimum": 1,
            "maximum": 4,
            "default": 1,
            "example": 1
          },
          "image_urls": {
            "type": "array",
            "description": "Reference image URLs for image-to-image or editing workflows.",
            "items": {
              "type": "string",
              "format": "uri"
            },
            "example": ["https://example.com/image1.png"]
          },
          "response_format": {
            "type": "string",
            "enum": ["url", "b64_json"],
            "default": "url",
            "description": "Return format for generated images."
          }
        }
      },
      "ImageGenerationResponse": {
        "type": "object",
        "properties": {
          "created": {
            "type": "integer",
            "description": "Unix timestamp when the response was created.",
            "example": 1757165031
          },
          "data": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "url": {
                  "type": "string",
                  "format": "uri",
                  "description": "URL of the generated image."
                },
                "b64_json": {
                  "type": "string",
                  "description": "Base64-encoded image when `response_format` is `b64_json`."
                }
              }
            }
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "properties": {
          "error": {
            "type": "object",
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" },
              "type": { "type": "string" }
            }
          }
        }
      }
    }
  }
}
